<!DOCTYPE html>
<html>
<head>
  <title>Inventory Application</title>
</head>
<body>
  <%- include('../header') %>
  <main>
    <form action="/items/<%= item.id %>/update" method="post">
        <h1>Edit item</h1>
        <div class="input">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" value="<%= item.name %>" required>
        </div>
        <div class="input">
            <label for="description">Description</label>
            <input type="text" id="description" name="description" value="<%= item.description %>">
        </div>
        <div class="input">
            <label for="quantity">Quantity</label>
            <input type="number" id="quantity" name="quantity" value="<%= item.quantity %>" min="0" required>
        </div>
        <button type="submit">Update</button>
    </form>
  </main>
</body>
</html>
