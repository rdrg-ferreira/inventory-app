<!DOCTYPE html>
<html>
<head>
  <title>Inventory Application</title>
  <script defer>
    function handleDeleteItemClick() {
        const modal = document.querySelector("div.class-modal");
        modal.classList.toggle("hidden");
    }
  </script>
</head>
<body>
  <%- include('../header') %>
  <main>
    <div>
        <h1><%= item.name %></h1>
        <p><%= item.description %></p>
        <span><%= item.quantity %> 📦</span>
        <div class="actions">
            <a href="/items/<%= item.id %>/update">Edit item</a>
            <button onclick="handleDeleteItemClick">Delete item</button>
        </div>
    </div>
  </main>
  <div class="delete-modal hidden">
    <span>Are you sure you want to delete this item?</span>
    <div class="actions">
        <a href="/items/<%= item.id %>/delete">Yes</a>
        <button onclick="handleDeleteItemClick">No</button>
    </div>
  </div>
</body>
</html>
